{
  "name": "tramio",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --runInBand",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "expo": "^57.0.0",
    "expo-build-properties": "~57.0.2",
    "expo-keep-awake": "~57.0.0",
    "expo-location": "~57.0.1",
    "expo-speech": "~57.0.0",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-task-manager": "~57.0.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@expo/config-plugins": "~57.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.14.10",
    "@types/react": "~19.2.4",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "better-sqlite3": "^12.10.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-native": "4.1.0",
    "fast-check": "3.23.2",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "react-test-renderer": "19.2.3",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
