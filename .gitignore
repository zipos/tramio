# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# test coverage (jest)
coverage/

# logs
*.log
logs/

# IDE / editor settings (per-developer, IDE-agnostic project)
.idea/
*.iml
# Keep shared VS Code settings if desired; ignore the noisy per-user bits.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS cruft
Thumbs.db
